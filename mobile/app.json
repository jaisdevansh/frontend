{
  "expo": {
    "name": "Entry Club",
    "slug": "entry-club",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "entry-club",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./src/assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0B10"
    },
    "androidStatusBar": {
      "barStyle": "light-content",
      "backgroundColor": "#0A0B10"
    },
    "primaryColor": "#0A0B10",
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.entryclub.app",
      "buildNumber": "1",
      "jsEngine": "hermes",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSUserNotificationsUsageDescription": "Entry Club sends you real-time updates about your bookings, orders, and events."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0B10"
      },
      "splash": {
        "image": "./src/assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#0A0B10",
        "mdpi": "./src/assets/images/splash-icon.png",
        "hdpi": "./src/assets/images/splash-icon.png",
        "xhdpi": "./src/assets/images/splash-icon.png",
        "xxhdpi": "./src/assets/images/splash-icon.png",
        "xxxhdpi": "./src/assets/images/splash-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.entryclub.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 3,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.USE_FULL_SCREEN_INTENT"
      ],
      "jsEngine": "hermes",
      "enableProguardInReleaseBuilds": true,
      "enableShrinkResourcesInReleaseBuilds": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/icon.png",
          "color": "#7C3AED",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "Entry Club",
          "iosDisplayInForeground": true
        }
      ],
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to find nearby events."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to upload profile and event images.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to take profile pictures."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "minSdkVersion": 24,
            "usesCleartextTraffic": false,
            "useLegacyPackaging": false,
            "enableMinifyInReleaseBuilds": true
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "ENV": "development",
      "router": {},
      "eas": {
        "projectId": "bb210273-63f6-48f0-97ad-9328fd0157b7"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ]
  }
}
